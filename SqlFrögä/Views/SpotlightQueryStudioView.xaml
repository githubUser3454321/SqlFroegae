<UserControl
    x:Class="SqlFroega.Views.SpotlightQueryStudioView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <StackPanel Spacing="10">
                <TextBlock Text="Spotlight-Suche" FontWeight="SemiBold" FontSize="20"/>

                <TextBox x:Name="PrimaryQueryTextBox"
                         Header="Volltextsuche"
                         PlaceholderText="z. B. Invoice oder Kundenkürzel"
                         TextChanged="PrimaryQueryTextBox_TextChanged"
                         TextWrapping="NoWrap"
                         MinHeight="44"
                         MaxHeight="120"
                         AcceptsReturn="True"/>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="ScopeCombo" Grid.Column="0" SelectedIndex="0">
                        <ComboBoxItem Content="Alle"/>
                        <ComboBoxItem Content="Global"/>
                        <ComboBoxItem Content="Kunde"/>
                        <ComboBoxItem Content="Modul"/>
                    </ComboBox>
                    <TextBox x:Name="MainModuleBox" Grid.Column="1" Header="Main-Modul" PlaceholderText="z. B. Einkauf"/>
                    <TextBox x:Name="RelatedModuleBox" Grid.Column="2" Header="Verknüpfte Module" PlaceholderText="komma-getrennt"/>
                    <ComboBox x:Name="FolderCombo" Grid.Column="3" Header="Folder" DisplayMemberPath="DisplayName" PlaceholderText="Alle"/>
                    <TextBox x:Name="CustomerCodeBox" Grid.Column="4" Header="Kundenkürzel" PlaceholderText="komma-getrennt"/>
                    <TextBox x:Name="TagsBox" Grid.Column="5" Header="Tags" PlaceholderText="komma-getrennt"/>
                    <TextBox x:Name="ObjectsBox" Grid.Column="6" Header="SQL-Objekte" PlaceholderText="komma-getrennt"/>
                    <ComboBox x:Name="CollectionCombo" Grid.Column="7" Header="Collection" DisplayMemberPath="Name" PlaceholderText="Alle"/>

                    <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Bottom" Spacing="8">
                        <Button Content="Suche starten" Click="SearchSpotlight_Click"/>
                        <CheckBox x:Name="SearchHistoryBox" Content="Historie" VerticalAlignment="Center"/>
                        <CheckBox x:Name="IncludeDeletedBox" Content="Gelöschte" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="SavedProfilesCombo"
                              Grid.Column="0"
                              Header="Suchprofile"
                              DisplayMemberPath="Name"
                              PlaceholderText="Profil auswählen"/>

                    <TextBox x:Name="ProfileNameBox" Grid.Column="1" Header="Profilname" PlaceholderText="z. B. Meine Favoriten-Suche"/>

                    <ComboBox x:Name="ProfileVisibilityCombo" Grid.Column="2" Header="Sichtbarkeit" SelectedIndex="0">
                        <ComboBoxItem Content="Für mich"/>
                        <ComboBoxItem Content="Für alle"/>
                    </ComboBox>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                        <Button Content="Laden" Click="LoadProfile_Click"/>
                        <Button Content="Speichern" Click="SaveProfile_Click"/>
                        <Button Content="Löschen" Click="DeleteProfile_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Column="4" x:Name="ProfileFeedbackText" VerticalAlignment="Bottom" Opacity="0.75" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="0"
                    Background="{ThemeResource AppCardBrush}">
                <Frame x:Name="SpotlightDetailFrame"/>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Gefundene Skripte" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Grid.Row="1" x:Name="ResultsHintText" Opacity="0.75" Text="Suche starten und Ergebnis anklicken, um das Session-Memory-Profil zu merken."/>
                    <ListView Grid.Row="2"
                              x:Name="SpotlightResultsList"
                              IsItemClickEnabled="True"
                              ItemClick="SpotlightResultsList_ItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Padding="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ScopeLabel}" Opacity="0.7"/>
                                    <TextBlock Text="{Binding MainModule}" Opacity="0.7"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
