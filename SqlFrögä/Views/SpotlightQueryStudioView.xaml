<UserControl
    x:Class="SqlFroega.Views.SpotlightQueryStudioView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12"
                    Padding="8,0,8,0">
            <TextBlock Text="Phase 1: Vollbildsuche mit Filter-Parität zur bestehenden erweiterten Suche."
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Nächster Schritt: AND/OR-Regelgruppen, Suchprofile und Tree-Zusatzfunktion."
                       TextWrapping="Wrap"
                       Opacity="0.85"/>

            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <TextBlock Text="Suchprofile"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="SavedProfilesCombo"
                              Header="Vorhandene Profile"
                              DisplayMemberPath="Name"
                              PlaceholderText="Profil auswählen"/>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="ProfileNameBox"
                                 Header="Profilname"
                                 PlaceholderText="z. B. Meine Favoriten-Suche"/>

                        <ComboBox x:Name="ProfileVisibilityCombo"
                                  Grid.Column="1"
                                  Header="Sichtbarkeit"
                                  MinWidth="160"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Für mich"/>
                            <ComboBoxItem Content="Für alle"/>
                        </ComboBox>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Bottom">
                            <Button Content="Laden"
                                    Click="LoadProfile_Click"/>
                            <Button Content="Speichern"
                                    Click="SaveProfile_Click"/>
                            <Button Content="Löschen"
                                    Click="DeleteProfile_Click"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="ProfileFeedbackText"
                               Opacity="0.75"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBox x:Name="PrimaryQueryTextBox"
                     Header="Regelgruppe 1: Freitext"
                     PlaceholderText="z. B. Invoice oder Kundenkürzel"/>

            <ComboBox x:Name="ScopeCombo" SelectedIndex="0">
                <ComboBoxItem Content="Bereich: Alle"/>
                <ComboBoxItem Content="Bereich: Global"/>
                <ComboBoxItem Content="Bereich: Kunde"/>
                <ComboBoxItem Content="Bereich: Modul"/>
            </ComboBox>

            <TextBox x:Name="MainModuleBox"
                     Header="Hauptmodul"
                     PlaceholderText="z. B. Einkauf"/>
            <TextBox x:Name="RelatedModuleBox"
                     Header="Verknüpfte Module"
                     PlaceholderText="komma-getrennt"/>
            <TextBox x:Name="CustomerCodeBox"
                     Header="Kundenkürzel"
                     PlaceholderText="komma-getrennt"/>
            <TextBox x:Name="TagsBox"
                     Header="Tags"
                     PlaceholderText="komma-getrennt"/>
            <TextBox x:Name="ObjectsBox"
                     Header="Referenzierte SQL-Objekte"
                     PlaceholderText="komma-getrennt"/>

            <CheckBox x:Name="IncludeDeletedBox"
                      Content="Gelöschte Datensätze anzeigen (Temporal)"/>
            <CheckBox x:Name="SearchHistoryBox"
                      Content="Auch in Historien-Versionen suchen"/>

            <ToggleSwitch x:Name="DisplayFolderStructureToggle"
                          Header="Display Folder Structure"/>

            <ComboBox x:Name="FolderCombo"
                      Header="Ordnerfilter"
                      DisplayMemberPath="DisplayName"
                      PlaceholderText="Alle Ordner"/>

            <ComboBox x:Name="CollectionCombo"
                      Header="Collection-Filter"
                      DisplayMemberPath="Name"
                      PlaceholderText="Alle Collections"/>

            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <TextBlock Text="AND/OR-Regelgruppen (Frontend-Phase 2)" FontWeight="SemiBold"/>
                    <ComboBox x:Name="GroupCombineModeCombo" Header="Gruppenverknüpfung" SelectedIndex="0" MinWidth="220">
                        <ComboBoxItem Content="AND (Schnittmenge)"/>
                        <ComboBoxItem Content="OR (Vereinigung)"/>
                    </ComboBox>

                    <CheckBox x:Name="EnableSecondGroupCheckBox" Content="Zweite Regelgruppe aktivieren"/>

                    <StackPanel x:Name="SecondGroupPanel" Spacing="8">
                        <TextBox x:Name="SecondQueryTextBox" Header="Regelgruppe 2: Freitext" PlaceholderText="optional"/>
                        <ComboBox x:Name="SecondScopeCombo" SelectedIndex="0">
                            <ComboBoxItem Content="Bereich: Alle"/>
                            <ComboBoxItem Content="Bereich: Global"/>
                            <ComboBoxItem Content="Bereich: Kunde"/>
                            <ComboBoxItem Content="Bereich: Modul"/>
                        </ComboBox>
                        <TextBox x:Name="SecondMainModuleBox" Header="Hauptmodul" PlaceholderText="z. B. Einkauf"/>
                        <TextBox x:Name="SecondRelatedModuleBox" Header="Verknüpfte Module" PlaceholderText="komma-getrennt"/>
                        <TextBox x:Name="SecondCustomerCodeBox" Header="Kundenkürzel" PlaceholderText="komma-getrennt"/>
                        <TextBox x:Name="SecondTagsBox" Header="Tags" PlaceholderText="komma-getrennt"/>
                        <TextBox x:Name="SecondObjectsBox" Header="Referenzierte SQL-Objekte" PlaceholderText="komma-getrennt"/>
                        <CheckBox x:Name="SecondIncludeDeletedBox" Content="Gelöschte Datensätze anzeigen (Temporal)"/>
                        <CheckBox x:Name="SecondSearchHistoryBox" Content="Auch in Historien-Versionen suchen"/>
                        <ComboBox x:Name="SecondFolderCombo" Header="Ordnerfilter" DisplayMemberPath="DisplayName" PlaceholderText="Alle Ordner"/>
                        <ComboBox x:Name="SecondCollectionCombo" Header="Collection-Filter" DisplayMemberPath="Name" PlaceholderText="Alle Collections"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
