<Page
    x:Class="SqlFroega.Views.ScriptItemView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SqlFroega.ViewModels"
    xmlns:models="using:SqlFroega.Application.Models"
    mc:Ignorable="d"
    Background="{ThemeResource AppPageBackgroundBrush}">

    <Page.DataContext>
        <vm:ScriptItemViewModel/>
    </Page.DataContext>

    <Grid Padding="16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <AutoSuggestBox Grid.Column="1"
                            x:Name="SelectedCustomerCodeAutoSuggest"
                            PlaceholderText="Kundenkürzel (z.B. CSA)"
                            Text="{Binding SelectedCustomerCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="CustomerCodeAutoSuggest_TextChanged"
                            SuggestionChosen="CustomerCodeAutoSuggest_SuggestionChosen"
                            GotFocus="CustomerCodeAutoSuggest_GotFocus"
                            DisplayMemberPath="CustomerCode"
                            TextMemberPath="CustomerCode"/>
            <Button Grid.Column="2"
                    x:Name="CopyButton"
                    Content="Kopieren"
                    Command="{Binding CopyCommand}"
                    CanDrag="True"
                    DragStarting="CopyButton_DragStarting" />
            <Button Grid.Column="3"
                    x:Name="CopyRenderedButton"
                    Content="Gerendert kopieren"
                    Command="{Binding CopyRenderedCommand}"
                    CanDrag="True"
                    DragStarting="CopyRenderedButton_DragStarting"/>
            <Button Grid.Column="4"
                    Content="Gerendert formatiert kopieren"
                    Command="{Binding CopyRenderedFormattedCommand}"/>
        </Grid>

        <Border Grid.Row="1"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="12">

            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="2.4*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ID" Opacity="0.75"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding NumberId, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="1"
                                    Command="{Binding CopyDeepLinkCommand}"
                                    ToolTipService.ToolTip="Deep-Link kopieren"
                                    VerticalAlignment="Stretch"
                                    MinWidth="36"
                                    Padding="0">
                                <SymbolIcon Symbol="Copy"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Name" Opacity="0.75"/>
                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsEditingEnabled, Converter={StaticResource BooleanNegationConverter}}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Geltungsbereich" Opacity="0.75"/>
                        <ComboBox SelectedIndex="{Binding Scope, Mode=TwoWay}" IsEnabled="{Binding IsEditingEnabled}">
                            <ComboBoxItem Content="Global"/>
                            <ComboBoxItem Content="Kunde"/>
                            <ComboBoxItem Content="Modul"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.8*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="0.8*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Main-Modul" Opacity="0.75"/>
                        <AutoSuggestBox PlaceholderText="Modul auswählen"
                                        Text="{Binding MainModule, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="MainModuleAutoSuggest_TextChanged"
                                        SuggestionChosen="MainModuleAutoSuggest_SuggestionChosen"
                                        GotFocus="MainModuleAutoSuggest_GotFocus"
                                        IsEnabled="{Binding IsEditingEnabled}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Verknüpfte Module" Opacity="0.75"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding RelatedModulesText}"
                                     IsReadOnly="True"
                                     Tapped="RelatedModulesTextBox_Tapped"/>
                            <Button Grid.Column="1" Content="Bearbeiten"
                                    Click="EditRelatedModules_Click"
                                    IsEnabled="{Binding IsEditingEnabled}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Folder" Opacity="0.75"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SelectedFolderName, Mode=OneWay}"
                                     IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Content="Auswählen"
                                    Click="OpenFolderPicker_Click"
                                    IsEnabled="{Binding IsEditingEnabled}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Kundenkürzel (z.B. CSA)" Opacity="0.75"/>
                        <AutoSuggestBox PlaceholderText="Kundenkürzel (z.B. CSA)"
                                        x:Name="ScriptCustomerCodeAutoSuggest"
                                        Text="{Binding ScriptCustomerCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="CustomerCodeAutoSuggest_TextChanged"
                                        SuggestionChosen="CustomerCodeAutoSuggest_SuggestionChosen"
                                        GotFocus="CustomerCodeAutoSuggest_GotFocus"
                                        DisplayMemberPath="CustomerCode"
                                        TextMemberPath="CustomerCode"
                                        IsEnabled="{Binding IsEditingEnabled}"/>
                    </StackPanel>
                </Grid>

                <CheckBox Grid.Row="2"
                          Content="DB-User und Prefix ersetzen (inkl. Sicherheitsprüfung auf USE/DB-Qualifier)"
                          IsChecked="{Binding ReplaceDatabaseUserAndPrefix, Mode=TwoWay}"
                          IsEnabled="{Binding IsEditingEnabled}"/>

                <Grid Grid.Row="3" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="SQL Content" Opacity="0.75"/>
                    <TextBox Grid.Row="1"
                             x:Name="SqlContentTextBox"
                             Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             KeyDown="SqlContentTextBox_KeyDown"
                             IsReadOnly="{Binding IsEditingEnabled, Converter={StaticResource BooleanNegationConverter}}"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch"
                             MinHeight="260"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

                    <StackPanel Grid.Row="2" Margin="0,6,0,0">
                        <TextBlock Text="Flags" Opacity="0.75"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding FlagsText}"
                                     IsReadOnly="True"
                                     Tapped="FlagsTextBox_Tapped"/>
                            <Button Grid.Column="1"
                                    Content="Flag hinzufügen"
                                    Click="EditFlags_Click"
                                    IsEnabled="{Binding IsEditingEnabled}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="HistorySection" Grid.Row="2"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="12">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Historie (temporal)" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="Aktualisieren" Command="{Binding RefreshHistoryCommand}"/>
                </Grid>

                <TextBlock Grid.Row="1" Text="{Binding HistoryCountText}" Opacity="0.75"/>

                <ListView Grid.Row="2" ItemsSource="{Binding HistoryItems}" IsItemClickEnabled="True" ItemClick="HistoryItems_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ScriptHistoryItem">
                            <Grid ColumnSpacing="12" Padding="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding ValidFrom}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ValidTo}"/>
                                <TextBlock Grid.Column="2" Text="{Binding ChangedBy}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="{Binding ChangeReason}" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>


        <Border x:Name="FolderPickerOverlay"
                Grid.RowSpan="4"
                Visibility="Collapsed"
                Background="#CC0E3A67"
                Padding="28"
                KeyDown="FolderPickerOverlay_KeyDown"
                IsTabStop="True">
            <Grid RowSpacing="12"
                  MaxWidth="1200"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="12" Margin="8,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Folder auswählen"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <Border Grid.Row="1"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Background="{ThemeResource AppCardBrush}"
                        Padding="16">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="NewFolderNameBox"
                                     PlaceholderText="Neuen Folder-Namen eingeben"/>

                            <Button Grid.Column="1"
                                    Content="Folder hinzufügen"
                                    Click="AddFolder_Click"/>

                            <Button Grid.Column="2"
                                    Content="Folder löschen"
                                    Click="DeleteFolder_Click"/>
                        </Grid>

                        <TreeView x:Name="FolderTreePicker"
                                  Grid.Row="1"
                                  ItemInvoked="FolderTreePicker_ItemInvoked"
                                  SelectionChanged="FolderTreePicker_SelectionChanged">
                            <TreeView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Content="Ohne Folder"
                            Click="ClearFolderSelection_Click"/>
                    <Button Content="Abbrechen"
                            Click="CloseFolderPicker_Click"/>
                    <Button Content="Folder auswählen"
                            Click="ApplyFolderSelection_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ProgressRing Width="18" Height="18" IsActive="{Binding IsBusy}" />
            <TextBlock Grid.Column="1" Text="{Binding Error}" Foreground="Tomato" TextWrapping="WrapWholeWords"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="🔓 Bearbeiten" Command="{Binding AcquireEditLockCommand}"/>
                <Button Content="Speichern" Click="Save_Click" IsEnabled="{Binding IsEditingEnabled}"/>
                <Button Content="Abbrechen" Click="Cancel_Click"/>
                <Button Content="Formatieren" Command="{Binding FormatSqlCommand}" IsEnabled="{Binding IsEditingEnabled}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
