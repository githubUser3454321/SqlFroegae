<Page
    x:Class="SqlFroega.Views.LibrarySplitView"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SqlFroega.ViewModels"
    xmlns:models="using:SqlFroega.Application.Models"
    Background="{ThemeResource AppPageBackgroundBrush}">

    <Page.DataContext>
        <vm:LibrarySplitViewModel />
    </Page.DataContext>
    
    

    <Grid Padding="16" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="440"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LINKS: Suche -->
        <Grid Grid.Column="0"
                Background="{ThemeResource AppPaneBackgroundBrush}"
                CornerRadius="16"
                Padding="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="SqlFrögä" FontSize="22" FontWeight="SemiBold"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Admin" Visibility="{Binding AdminButtonVisibility}">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Kunden-Mapping Verwaltung"
                                            Click="CustomerMappingAdmin_Click"/>
                            <MenuFlyoutItem Text="Modul Verwaltung"
                                            Click="ModuleAdmin_Click"/>
                            <MenuFlyoutItem Text="Benutzerverwaltung"
                                            Click="UserManagementAdmin_Click"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button Grid.Column="2"
                        Content="Neu"
                        Command="{Binding NewCommand}"/>

                <Button Grid.Column="3"
                        Content="Abmelden"
                        Command="{Binding LogoutAndCloseCommand}"/>
            </Grid>

            <!-- Search bar -->
            <Border Grid.Row="1"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 PlaceholderText="Globale Suche (Volltext, Module, Kundenkürzel, Tags)…"
                                 Text="{Binding QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="QueryTextBox_KeyDown"/>

                        <Button Grid.Column="1"
                                Content="Suchen"
                                Command="{Binding SearchCommand}"/>

                        <ToggleButton Grid.Column="2"
                                      ToolTipService.ToolTip="Erweiterte Suche ein-/ausblenden"
                                      MinWidth="100"
                                      Foreground="Black"
                                      IsChecked="{Binding IsAdvancedSearchExpanded, Mode=TwoWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE71C;" Foreground="Black"/>
                                <TextBlock Text="Filter" Foreground="Black"/>
                            </StackPanel>
                        </ToggleButton>
                    </Grid>

                    <Border Grid.Row="1"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            Padding="0,12,0,0"
                            Margin="0,8,0,0"
                            Visibility="{Binding IsAdvancedSearchExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ScrollViewer MaxHeight="560" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Padding="0" RowSpacing="8" ColumnSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Row="0" Grid.Column="0" SelectedIndex="{Binding ScopeFilterIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="Bereich: Alle"/>
                                        <ComboBoxItem Content="Bereich: Global"/>
                                        <ComboBoxItem Content="Bereich: Kunde"/>
                                        <ComboBoxItem Content="Bereich: Modul"/>
                                    </ComboBox>

                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             PlaceholderText="Hauptmodul"
                                             Text="{Binding MainModuleFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             PlaceholderText="Verknüpfte Module (komma-getrennt)"
                                             Text="{Binding RelatedModuleFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             PlaceholderText="Kundenkürzel"
                                             Text="{Binding CustomerCodeFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                             PlaceholderText="Tags, komma-getrennt"
                                             Text="{Binding TagsFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                             PlaceholderText="Objektsuche (einzeln oder komma-getrennt)"
                                             Text="{Binding ObjectFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <CheckBox Grid.Row="4" Grid.Column="0"
                                              Content="Gelöschte Datensätze anzeigen (Temporal)"
                                              IsChecked="{Binding IncludeDeleted, Mode=TwoWay}"/>

                                    <CheckBox Grid.Row="4" Grid.Column="1"
                                              Content="Auch in Historien-Versionen suchen"
                                              IsChecked="{Binding SearchInHistory, Mode=TwoWay}"/>

                                    <Expander Grid.Row="6" Grid.ColumnSpan="2" Header="Tag- &amp; Modul-Katalog" IsExpanded="False">
                                        <StackPanel Spacing="8" Padding="0,8,0,0">
                                            <Button Content="Katalog aktualisieren" HorizontalAlignment="Left" Command="{Binding RefreshCatalogCommand}"/>

                                            <TextBlock Text="Modul-Katalog" FontWeight="SemiBold"/>
                                            <TextBox PlaceholderText="Module filtern"
                                                     Text="{Binding ModuleCatalogSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Text="Hauptmodule" Opacity="0.75"/>
                                            <ListView ItemsSource="{Binding FilteredMainModules}" SelectionMode="None" MaxHeight="120">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding}" HorizontalAlignment="Stretch"
                                                                Command="{Binding DataContext.ApplyModuleFilterCommand, ElementName=RootPage}"
                                                                CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>

                                            <TextBlock Text="Verknüpfte Module" Opacity="0.75"/>
                                            <ListView ItemsSource="{Binding FilteredRelatedModules}" SelectionMode="None" MaxHeight="120">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding}" HorizontalAlignment="Stretch"
                                                                Command="{Binding DataContext.ApplyRelatedModuleFilterCommand, ElementName=RootPage}"
                                                                CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>

                                            <TextBlock Text="Tags" FontWeight="SemiBold"/>
                                            <TextBox PlaceholderText="Tags filtern"
                                                     Text="{Binding TagCatalogSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <ListView ItemsSource="{Binding FilteredTags}" SelectionMode="None" MaxHeight="160">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding}" HorizontalAlignment="Stretch"
                                                                Command="{Binding DataContext.ToggleTagFilterCommand, ElementName=RootPage}"
                                                                CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </Expander>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                </Grid>
            </Border>

            <!-- Results -->
            <Border Grid.Row="2"
                    CornerRadius="12"
                    BorderThickness="1"
                    Background="{ThemeResource AppCardBrush}"
                    BorderBrush="{ThemeResource AppCardBorderBrush}"
                    Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ProgressRing Width="20" Height="20" IsActive="{Binding IsBusy}" />
                        <TextBlock Grid.Column="1" Text="{Binding ResultsCountText}" VerticalAlignment="Center" Opacity="0.8"/>
                    </Grid>

                    <ListView x:Name="ResultsList" Grid.Row="1"
                              ItemsSource="{Binding Results}"
                              SelectedItem="{Binding Selected, Mode=TwoWay}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              SizeChanged="ResultsList_SizeChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ScriptListItem">
                                <Border CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        Background="{ThemeResource AppCardBrush}"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding NumberId}" Opacity="0.7" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}" Opacity="0.8" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding DeletedLabel}" Foreground="Tomato" FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <!-- Edit/Delete per CommandParameter -->
                                            <Button Content="Bearbeiten"
                                                    Command="{Binding DataContext.EditCommand, ElementName=ResultsList}"
                                                    CommandParameter="{Binding Id}"/>
                                            <Button Content="Löschen"
                                                    Click="DeleteButton_Click"
                                                    Tag="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2"
                          ColumnSpacing="8"
                          Visibility="{Binding PaginationVisibility}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="← Zurück"
                                Command="{Binding PreviousPageCommand}"/>
                        <Button Grid.Column="1"
                                Content="Weiter →"
                                Command="{Binding NextPageCommand}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Error -->
            <TextBlock Grid.Row="3"
                       Text="{Binding Error}"
                       Foreground="Tomato"
                       TextWrapping="WrapWholeWords"
                       Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <!-- RIGHT: Detail -->
        <Border Grid.Column="1"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                Padding="0"
                Background="{ThemeResource AppCardBrush}">
            <Grid>
                <Frame x:Name="DetailFrame"/>
            </Grid>
        </Border>
    </Grid>
</Page>
