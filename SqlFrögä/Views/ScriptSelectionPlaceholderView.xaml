<Page
    x:Class="SqlFroega.Views.ScriptSelectionPlaceholderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppPageBackgroundBrush}">

    <Border CornerRadius="12"
            BorderThickness="1"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Padding="24"
            Margin="16">
        <StackPanel Spacing="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="520">
            <TextBlock Text="Kein Skript ausgewählt"
                       FontSize="24"
                       FontWeight="SemiBold"
                       TextAlignment="Center"/>
            <TextBlock Text="Bitte wähle links ein bestehendes Item aus oder klicke auf &#34;Neu&#34;, um ein neues Skript zu erstellen."
                       Opacity="0.8"
                       TextWrapping="WrapWholeWords"
                       TextAlignment="Center"/>
        </StackPanel>
    </Border>
</Page>
